# ============================================================================
# crossmint-wallets-mcp — environment template
# ============================================================================
# Copy to `.env` and fill in. `.env` is gitignored; never commit real values.

# ------------------------------------------------------------
# Crossmint API key
# ------------------------------------------------------------
# Create a server API key at https://www.crossmint.com/console
# Required scopes:
#   wallets.create
#   wallets.read
#   wallets:transactions.create
#   wallets:transactions.sign
#   wallets:balance.read
#
# Provide EITHER of the following (direct value wins if both are set):
CROSSMINT_API_KEY=

# ...or a file path if you prefer to keep secrets outside the project
# (useful for Docker secrets, Kubernetes secrets, or to avoid accidental
# display during screen shares). The file must contain only the key value.
# CROSSMINT_API_KEY_FILE=/run/secrets/crossmint-api-key

# ------------------------------------------------------------
# Server recovery signer secret
# ------------------------------------------------------------
# Any random 32+ character string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This secret controls server-side wallet recovery — never share or commit.
CROSSMINT_RECOVERY_SECRET=

# Or use the file-ref pattern:
# CROSSMINT_RECOVERY_SECRET_FILE=/run/secrets/crossmint-recovery-secret

# ------------------------------------------------------------
# Default chain for new wallets
# ------------------------------------------------------------
# Allowed: solana | solana-devnet | base | base-sepolia
# We default to solana-devnet so you can safely experiment without real funds.
DEFAULT_CHAIN=solana-devnet

# ------------------------------------------------------------
# Solana RPC endpoint
# ------------------------------------------------------------
# Default is the public mainnet-beta RPC. For devnet testing use:
#   https://api.devnet.solana.com
# For production, point to a private RPC (QuickNode, Helius, Triton, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
